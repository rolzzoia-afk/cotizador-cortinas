# ══════════════════════════════════════════════════════════════════════
#  Variables de entorno — Rolzzo
#  Copiar a .env.local para desarrollo local.
#  En Vercel: Settings → Environment Variables
# ══════════════════════════════════════════════════════════════════════

# ── Frontend (Vite) — expuestas al cliente ──────────────────────────
VITE_SUPABASE_URL=https://izelewwgeamktnzkiwvl.supabase.co
VITE_SUPABASE_ANON_KEY=           # ← Supabase → Settings → API → anon key
VITE_APP_NAME=                    # ← nombre del producto en pantallas pre-login (vacío = Rolzzo)

# ── Error tracking (Sentry) ────────────────────────────────────────
# Dejar vacío para desactivar (no-op en local). Crear proyecto en sentry.io,
# copiar el DSN y pegarlo en .env.local + Vercel Environment Variables.
VITE_SENTRY_DSN=
VITE_APP_VERSION=dev              # ← usar el SHA de git en CI, "dev" en local

# ── Backend (serverless /api) — solo servidor ───────────────────────
SUPABASE_URL=https://izelewwgeamktnzkiwvl.supabase.co
SUPABASE_SERVICE_ROLE_KEY=        # ← Supabase → Settings → API → service_role key
